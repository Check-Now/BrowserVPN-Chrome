{
  "manifest_version": 3,
  "name": "BrowserVPN-Chrome",
  "version": "0.1.0",
  "key": "",
  "description": "Proxy regular Chrome pages through a local sing-box node.",
  "permissions": ["proxy", "storage", "nativeMessaging", "alarms"],
  "optional_host_permissions": ["https://*/*", "http://*/*"],
  "action": {
    "default_title": "BrowserVPN-Chrome",
    "default_popup": "popup.html"
  },
  "background": {
    "service_worker": "assets/background.js",
    "type": "module"
  },
  "options_page": "options.html",
  "minimum_chrome_version": "116"
}
